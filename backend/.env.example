# ===== Server =====
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# ===== Database =====
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/meeting_scheduler?retryWrites=true&w=majority

# ===== JWT =====
# Use a long random string (e.g. `openssl rand -base64 48`)
JWT_SECRET=your_long_random_secret_here
JWT_EXPIRES_IN=7d
COOKIE_NAME=ms_token

# ===== Google OAuth =====
# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ===== Google Service Account (attendance via Admin SDK Reports API) =====
# Download JSON key, place at backend/credentials/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourdomain.com

# ===== Email (Gmail SMTP) =====
EMAIL_PROVIDER=gmail
EMAIL_USER=you@yourdomain.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=Meeting Scheduler

# ===== Redis (reminders queue) =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Misc =====
TIMEZONE=Asia/Kolkata
